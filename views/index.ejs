<!DOCTYPE html>
<html lang="et">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= cv.fName %> <%= cv.lName %> CV</title>
    <link href="https://fonts.googleapis.com/css2?family=Audiowide&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="css/style.css">
    <script src="https://kit.fontawesome.com/c3b0f38585.js" crossorigin="anonymous"></script>
</head>
<body>
    <div class="container">
        <header>
            <div class="profile-pic">
                <img src="images/mina1.png" alt="<%= cv.fName %> <%= cv.lName %>">
            </div>
            <div class="header">
                <h1><%= cv.fName %> <%= cv.lName %></h1>
                
                <div class="rating">
                    <ul class="rating-stars">
                        <li><i class="fa-solid fa-star"></i></li>
                        <li><i class="fa-solid fa-star"></i></li>
                        <li><i class="fa-solid fa-star"></i></li>
                        <li><i class="fa-solid fa-star"></i></li>
                        <li><i class="fa-solid fa-star"></i></li>
                    </ul>
                    <span class="rating-count">(67)</span>
                </div>
                <ul class="subtitle"><%= cv.role %> | Vanus: <%= cv.age %></ul>
            </div>
        </header>

        <section class="main">
            <div class="minust-container">
                <h2>Minust</h2>
                <p><%= cv.about %></p>
            </div>

            <div class="section">
                <h2>Tööülesanded</h2>
                <ul class="entry-list">
                    <% cv.tasks.forEach(function(task) { %>
                        <li><%= task %></li>
                    <% }); %>
                </ul>
            </div>

            <div class="section">
                <h2>Haridus</h2>
                <% cv.education.forEach(function(edu) { %>
                    <ul><%= edu %></ul>
                <% }); %>
            </div>

            <div class="columns">
                <div class="column">
                    <h2>Oskused</h2>
                    <ul class="entry-list">
                        <% cv.skills.forEach(function(skill) { %>
                            <li><%= skill %></li>
                        <% }); %>
                    </ul>
                </div>
                <div class="column">
                    <h2>Keeled</h2>
                    <ul class="entry-list">
                        <% cv.languages.forEach(function(lang) { %>
                            <li><%= lang %></li>
                        <% }); %>
                    </ul>
                </div>
            </div>

            <div class="footer">
                <h2>Kontakt</h2>
                <ul>E-post: <%= cv.email %></ul>
                <ul>Telefon: <%= cv.phone %></ul>
            </div>
        </section>
    </div>

    <script src="app.js"></script>
</body>
</html>